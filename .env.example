# ---- Web (Next.js) ----
# Public URL of the signaling server, reachable from browsers.
NEXT_PUBLIC_SIGNALING_URL=http://localhost:4000

# ---- Signaling server ----
PORT=4000
HOST=0.0.0.0
# Comma separated list of allowed browser origins for HTTP + WebSocket.
# In development, private-network origins (localhost, 10.x, 172.16-31.x,
# 192.168.x) are also accepted automatically so LAN devices can join.
ALLOWED_ORIGINS=http://localhost:3000
# Optional TLS for the signaling server itself (needed when the web app is
# served over https, e.g. `npm run dev:https`). In development the pair that
# Next generates in apps/web/certificates is picked up automatically when
# these are unset; set them to override (required for TLS in production).
TLS_CERT_FILE=
TLS_KEY_FILE=
# Optional: Redis for presence + horizontal scaling. Falls back to in-memory when unset.
REDIS_URL=
# Secret used to hash host/reconnect tokens. Required in production; in
# development a temporary secret is generated automatically when unset.
ROOM_TOKEN_SECRET=change-me-to-a-long-random-string

# ---- Room behaviour ----
ROOM_CODE_LENGTH=8
MAX_ROOM_PARTICIPANTS=5
DEFAULT_ROOM_TTL_MINUTES=240
HOST_RECONNECT_GRACE_SECONDS=90

# ---- ICE / TURN ----
# Comma separated STUN urls.
STUN_URLS=stun:stun.l.google.com:19302
# Static TURN credentials (MVP). Leave TURN_URL empty to disable TURN.
TURN_URL=
TURN_USERNAME=
TURN_CREDENTIAL=
# When set, /api/turn-credentials issues short-lived HMAC credentials (coturn
# `use-auth-secret` mode) instead of the static ones above.
TURN_STATIC_AUTH_SECRET=
TURN_CREDENTIAL_TTL_SECONDS=3600
